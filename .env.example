# Configuration for Cognee to use Google Vertex AI (Gemini)

LLM_PROVIDER=google_vertex_ai
LLM_MODEL=gemini-1.5-pro

# Provide the path to your service account key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# Optional: Setting the embedding provider to Vertex AI
EMBEDDING_PROVIDER=google_vertex_ai
