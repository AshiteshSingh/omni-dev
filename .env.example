# ============================================================
# Omni-Dev Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Active Model (LiteLLM format) ────────────────────────────
# Set this to whichever provider/model you want to use.
# Switch at runtime with the /model command.
OMNI_MODEL=vertex_ai/gemini-1.5-pro

# ── Google Cloud / Vertex AI (Gemini) ────────────────────────
# Required for: vertex_ai/gemini-1.5-pro, vertex_ai/gemini-2.0-flash
# Used by: Cognee memory backend (LLM + embeddings)
LLM_PROVIDER=google_vertex_ai
LLM_MODEL=gemini-1.5-pro
EMBEDDING_PROVIDER=google_vertex_ai
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json
# Optional: GCP project ID (usually auto-detected from credentials)
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# CLOUD_ML_REGION=us-central1

# ── Anthropic Claude ─────────────────────────────────────────
# Required for: claude-3-5-sonnet-20241022, claude-3-opus-20240229
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI GPT ───────────────────────────────────────────────
# Required for: gpt-4o, gpt-4o-mini, gpt-4-turbo
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Groq (Fast inference: Llama, Mixtral, Gemma) ─────────────
# Required for: groq/llama3-70b-8192, groq/mixtral-8x7b-32768
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ── Google Gemini API (Direct, not Vertex) ───────────────────
# Required for: gemini/gemini-1.5-pro, gemini/gemini-2.0-flash
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ── Cohere ───────────────────────────────────────────────────
# Required for: cohere/command-r-plus
COHERE_API_KEY=...

# ── Mistral AI ───────────────────────────────────────────────
# Required for: mistral/mistral-large-latest
MISTRAL_API_KEY=...

# ── Together AI ──────────────────────────────────────────────
# Required for: together_ai/meta-llama/Llama-3-70b-chat-hf
TOGETHERAI_API_KEY=...

# ── AWS Bedrock ──────────────────────────────────────────────
# Required for: bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0
# Uses your AWS credentials (configure via aws configure or env vars)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION_NAME=us-east-1

# ── Local Ollama ─────────────────────────────────────────────
# Required for: ollama/llama3, ollama/codellama, ollama/mistral
# No key needed — just run: ollama serve
# Install: https://ollama.ai
# OLLAMA_API_BASE=http://localhost:11434

# ── Web Search (SearXNG) ─────────────────────────────────────
# Optional: Self-hosted SearXNG instance for web search tool
# Public fallback: https://searx.be (rate-limited)
# SEARXNG_URL=https://searx.be

# ── Cognee Memory Backend ────────────────────────────────────
# Cognee uses the LLM_PROVIDER above for its own reasoning.
# Graph DB (default: SQLite, built-in — no config needed)
# For production, you can configure PostgreSQL + pgvector:
# GRAPH_DATABASE_PROVIDER=networkx
# VECTOR_DB_PROVIDER=lancedb
